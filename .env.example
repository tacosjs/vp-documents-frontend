# Rust API (no trailing slash). Must match backend FRONTEND_ORIGIN for credentialed CORS.
# From repo root, ./dev.sh creates this file from .env.example if missing and starts the full stack.
VITE_API_BASE_URL=http://localhost:7000

# Per-domain TanStack Query mocks (string "true" / "false"). Leave unset for real API.
# VITE_MOCK_AUTH=true
# VITE_MOCK_DOCUMENTS=true
# VITE_MOCK_USER_KEYS=true
